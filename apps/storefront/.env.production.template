# ===== ControlKart Storefront — PRODUCTION env =====
# Copy into your host's env settings. NEXT_PUBLIC_* are inlined at BUILD time,
# so set them before/at build (Docker build args or the platform's build env).

# Backend API (your deployed Medusa URL)
NEXT_PUBLIC_MEDUSA_BACKEND_URL=https://api.yourdomain.in
MEDUSA_BACKEND_URL=https://api.yourdomain.in

# Publishable API key — from Medusa Admin > Settings > Publishable API Keys.
# The one migrated from acme_medusa works, or create a fresh key in prod admin.
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_<your_publishable_key>

# Public site URL (used for canonical URLs, absolute asset paths)
NEXT_PUBLIC_BASE_URL=https://yourdomain.in

# Razorpay checkout key (public) — set when payments go live
NEXT_PUBLIC_RAZORPAY_KEY=
