{
  "name": "@controlkart/medusa",
  "version": "0.1.0",
  "description": "ControlKart commerce - Medusa v2 backend and admin.",
  "author": "ControlKart",
  "license": "MIT",
  "keywords": [
    "sqlite",
    "postgres",
    "typescript",
    "ecommerce",
    "headless",
    "medusa"
  ],
  "scripts": {
    "build": "medusa build",
    "predeploy": "medusa db:migrate",
    "seed": "medusa exec ./src/scripts/seed.ts",
    "setup:nested-specs": "medusa exec ./src/scripts/setup-nested-plc-specs.ts",
    "start": "medusa start",
    "dev": "medusa develop",
    "test:integration:http": "TEST_TYPE=integration:http NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:integration:modules": "TEST_TYPE=integration:modules NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:unit": "TEST_TYPE=unit NODE_OPTIONS=--experimental-vm-modules jest --silent --runInBand --forceExit"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@medusajs/admin-sdk": "2.15.3",
    "@medusajs/cli": "2.15.3",
    "@medusajs/framework": "2.15.3",
    "@medusajs/icons": "^2.15.3",
    "@medusajs/medusa": "2.15.3",
    "@medusajs/ui": "^4.1.15",
    "@sam-ael/medusa-plugin-shiprocket": "^0.2.1",
    "@uiw/react-md-editor": "^4.1.1",
    "medusa-plugin-razorpay-v2": "^0.1.4",
    "meilisearch": "0.56.0",
    "resend": "^6.14.0"
  },
  "devDependencies": {
    "@medusajs/test-utils": "2.15.3",
    "@swc/core": "^1.7.28",
    "@swc/jest": "^0.2.36",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.12.11",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.2.25",
    "jest": "^29.7.0",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2",
    "vite": "^5.4.14",
    "yalc": "^1.0.0-pre.53"
  },
  "engines": {
    "node": ">=20"
  }
}
