# Core
DATABASE_URL=postgres://localhost/controlkart_medusa
# REDIS_URL=redis://localhost:6379   # required in production
JWT_SECRET=supersecret
COOKIE_SECRET=supersecret
STORE_CORS=http://localhost:3000,http://localhost:8000
ADMIN_CORS=http://localhost:9000,http://localhost:5173,http://localhost:7001
AUTH_CORS=http://localhost:3000,http://localhost:9000,http://localhost:5173,http://localhost:8000

# Storefront URL (used in emails / redirects)
STOREFRONT_URL=http://localhost:3000

# Razorpay (payments)
RAZORPAY_ID=
RAZORPAY_SECRET=
RAZORPAY_ACCOUNT=
RAZORPAY_WEBHOOK_SECRET=

# Google OAuth (customer sign-in). The callback is the STOREFRONT page
# /auth/google/callback (client-side SDK flow) — NOT a backend route. This exact
# URL must also be added to the Google Cloud OAuth client's authorized redirect
# URIs. Storefront dev runs on :3000.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Email verification (optional — logs link to console in dev without Resend).
# To test real Resend delivery locally, set RESEND_API_KEY and an EMAIL_FROM on
# your VERIFIED domain (onboarding@resend.dev only mails the account owner).
RESEND_API_KEY=
EMAIL_FROM=ControlKart <noreply@controlkart.com>

# S3-compatible file storage (Cloudflare R2 etc). Leave empty to use local storage in dev.
S3_FILE_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto
S3_BUCKET=
S3_ENDPOINT=

# Shiprocket (fulfillment)
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
SHIPROCKET_PICKUP_LOCATION=Primary

# Meilisearch (self-hosted — internal network hostname; the API key here
# should be the instance's scoped Default Admin API Key, NOT the master key)
MEILISEARCH_HOST=
MEILISEARCH_API_KEY=
MEILISEARCH_PRODUCT_INDEX_NAME=products

# Company GST details (used on invoices)
COMPANY_GSTIN=
COMPANY_STATE=Maharashtra
COMPANY_STATE_CODE=27
