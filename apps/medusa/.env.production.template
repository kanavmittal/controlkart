# ===== ControlKart Medusa — PRODUCTION env =====
# Copy these into your host's environment settings (Coolify env UI / panel).
# Do NOT commit a filled-in copy. Replace every <PLACEHOLDER> and yourdomain.in.

# --- Instance mode (single shared instance is fine for launch) ---
MEDUSA_WORKER_MODE=shared
DISABLE_MEDUSA_ADMIN=false
NODE_ENV=production

# --- Database: PlanetScale (already in ap-south-2 / India) ---
DATABASE_URL=postgresql://<USER>:<PASSWORD>@<HOST>:5432/<DB>
# SSL is enforced in medusa-config.ts (verified). Set DATABASE_SSL=false only for a plain (non-TLS) Postgres.

# --- Redis: self-hosted on the same VPS (recommended) e.g. redis://default:<pw>@redis:6379
#     or Upstash Mumbai on a FIXED plan (free/PAYG burns out under BullMQ polling). ---
REDIS_URL=redis://<USER>:<PASSWORD>@<REDIS_HOST>:6379

# --- Secrets — paste the generated values straight into your host's env UI,
#     not into this file. Generate with: openssl rand -base64 32 ---
JWT_SECRET=<paste-generated-secret>
COOKIE_SECRET=<paste-generated-secret>

# --- Public URL + CORS (use HTTPS domains once DNS/TLS are set) ---
MEDUSA_BACKEND_URL=https://api.yourdomain.in
STORE_CORS=https://yourdomain.in
ADMIN_CORS=https://api.yourdomain.in
AUTH_CORS=https://yourdomain.in,https://api.yourdomain.in
STOREFRONT_URL=https://yourdomain.in

# --- Tax / region (Maharashtra = 27) ---
COMPANY_STATE_CODE=27

# --- Media storage: Cloudflare R2 (S3-compatible). REQUIRED in prod — local disk
#     does not survive container restarts/redeploys. The S3 provider is already
#     wired in medusa-config.ts; it activates automatically when S3_BUCKET is set. ---
S3_BUCKET=controlkart-media
S3_ENDPOINT=https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
S3_REGION=auto
S3_ACCESS_KEY_ID=<R2_ACCESS_KEY_ID>
S3_SECRET_ACCESS_KEY=<R2_SECRET_ACCESS_KEY>
S3_FILE_URL=https://media.yourdomain.in   # R2 public/custom-domain URL for serving files

# --- Payments: Razorpay (set when going live) ---
# RAZORPAY_ID=
# RAZORPAY_SECRET=
# RAZORPAY_ACCOUNT=
# RAZORPAY_WEBHOOK_SECRET=

# --- Customer Google sign-in (optional) ---
# The callback is the STOREFRONT page /auth/google/callback (client-side SDK
# flow), NOT a backend route. This exact URL must also be listed under the
# Google Cloud OAuth client's "Authorized redirect URIs".
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=https://controlkart.com/auth/google/callback

# --- Email: Resend (transactional — email verification, password reset) ---
# RESEND_API_KEY is REQUIRED in prod; without it the Notification module falls
# back to the local console-logging provider and NO email is actually sent.
RESEND_API_KEY=<RESEND_API_KEY>
# EMAIL_FROM must be an address on a domain VERIFIED in Resend
# (https://resend.com/domains -> add domain -> publish its SPF/DKIM DNS records).
# Do NOT use onboarding@resend.dev: that sender only delivers to the Resend
# account owner's own email -- mail to any other recipient fails with a 403.
EMAIL_FROM=ControlKart <noreply@controlkart.com>
