# Strapi (ControlKart CMS) — env template.
# Copy to .env for local dev; set these as environment variables on Dokploy in prod.

HOST=0.0.0.0
PORT=1337

# --- Secrets: GENERATE FRESH values for production ---
# e.g. node -e "console.log(require('crypto').randomBytes(16).toString('base64'))"
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified

# --- Database: reuse the Medusa Postgres, isolated in its own schema ---
DATABASE_CLIENT=postgres
DATABASE_URL=postgresql://user:pass@host:5432/dbname
DATABASE_SCHEMA=strapi
DATABASE_SSL=true

# Public URL of this Strapi instance (used by the admin panel).
STRAPI_ADMIN_BACKEND_URL=https://cms.controlkart.com

# Local dev with sqlite instead of postgres:
# DATABASE_CLIENT=sqlite
# DATABASE_FILENAME=.tmp/data.db
